	(text "Cl := 9pF\nCl = (C1*C2)/(C1 + C2) + Cparasitic\n\nlet C1 = C2\nCl = C1*C1/2*C1 + Cparasitic\nCl = C1/2 + Cparasitic\nCl - Cparasitic = C1/2\n2(Cl - Cparasitic) = C1\nC1 = 2(Cl - Cparasitic)\nCparasitic appx= 2pF - 5pF\n\nlet Cparasitic = 2pF\nC1 = 2(9pF - 2pF) = 14pF\n\nlet Cparasitic = 5pF\nC1 = 2(9pF - 5pF) = 8pF\n\npick C1 = 10pF"
		(exclude_from_sim no)
